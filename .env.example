# ============================================================
# Video Thumbnail Generator Bot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Telegram API Credentials ---
# Get these from https://my.telegram.org/apps
API_ID=12345678
API_HASH=your_api_hash_here

# Bot token from @BotFather
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrstUVwxyz

# --- rclone Configuration ---
# Name of your rclone remote (as configured in rclone.conf)
RCLONE_REMOTE=gdrive

# Default Google Drive path to scan for videos
RCLONE_PATH=/Videos

# Path to rclone config directory on the host machine
RCLONE_CONFIG_PATH=~/.config/rclone

# --- Web App ---
# Public URL where the dashboard is accessible
# This is used for the Telegram Web App button
WEBAPP_URL=https://your-domain.com

# WebSocket URL for the dashboard to connect to the bot
# In production, this should be your public domain
NEXT_PUBLIC_WS_URL=http://localhost:8765
NEXT_PUBLIC_API_URL=http://localhost:8765

# --- RAM Monitoring ---
# Pause processing when RAM usage exceeds this percentage
RAM_THRESHOLD_PERCENT=85

# Emergency cleanup when RAM exceeds this percentage
RAM_CRITICAL_PERCENT=95

# --- Authorization ---
# Space-separated Telegram user IDs allowed to use the bot
# Set to 0 to allow all users
AUTH_USERS=0

# --- Target Channel (Optional) ---
# Send uploaded videos and screenshots directly to a Telegram Channel instead of your private chat.
# Can be a channel username (e.g., @mychannel) or numeric channel ID (e.g., -1001234567890).
# NOTE: The bot MUST be added as an Administrator in the target channel!
CHANNEL_ID=
TARGET_CHANNEL=
